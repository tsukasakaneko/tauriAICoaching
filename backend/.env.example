PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-api-key...
ANTHROPIC_MODEL=claude-sonnet-4-6
DB_PATH=./coaching.db

# ── Riot ID SSO (Issue #17) ──────────────────────────────────────────────────
# Obtain RIOT_CLIENT_ID and RIOT_CLIENT_SECRET from https://developer.riotgames.com
# Register http://127.0.0.1:3001/auth/riot/callback as the redirect_uri.
# Leave blank to disable Riot linking (app functions normally without it).
RIOT_CLIENT_ID=
RIOT_CLIENT_SECRET=
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required when RIOT_CLIENT_ID is set — server will exit(1) if missing.
RIOT_ENCRYPTION_KEY=
# Override the Riot API region (default: ap for Asia-Pacific / Japan)
# RIOT_REGION=ap
